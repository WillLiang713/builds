# Copy to .env only if you want to override defaults.

# Match the WSL user by default so files created by the container remain editable.
LOCAL_UID=1000
LOCAL_GID=1000

UPSTREAM_REPO=https://github.com/padavanonly/immortalwrt-mt798x-6.6.git

# Inherit upstream's MT7981 closed-driver/HNAT/WARP defaults, while the scripts
# replace its multi-device target selection with the CMCC RAX3000M profile.
BASE_DEFCONFIG=/workspace/source/defconfig/mt7981-ax3000.config

# Empty means: use the upstream default branch on first clone, then keep the
# existing checkout. Set a branch, tag, or commit for reproducible builds.
UPSTREAM_REF=

# CMCC RAX3000M NAND with the OpenWrt U-Boot layout.
# Do not use cmcc_rax3000me unless the hardware is explicitly RAX3000Me.
# Do not use cmcc_rax3000m-nand-mtk for this OpenWrt U-Boot layout.
DEVICE_PROFILE=cmcc_rax3000m
DEVICE_KEYWORDS=cmcc,rax3000m
DEVICE_VARIANT_KEYWORD=

NIKKI_FEED_NAME=nikki
NIKKI_FEED_URL=https://github.com/nikkinikki-org/OpenWrt-nikki.git
NIKKI_FEED_BRANCH=main
NIKKI_MIHOMO_PROVIDER=mihomo-meta

# Empty means the scripts use nproc inside the container.
JOBS=
BUILD_VERBOSE=0
