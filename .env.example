# Copy to .env only if you want to override defaults.

# Match the local user by default so files created by the container remain editable.
LOCAL_UID=1000
LOCAL_GID=1000

UPSTREAM_REPO=https://github.com/padavanonly/immortalwrt-mt798x-6.6.git

# Empty means the scripts choose a Filogic base defconfig from the selected
# device DTS. Set an explicit path only when you need to override that choice.
BASE_DEFCONFIG=

# Empty means: use the upstream default branch on first clone, then keep the
# existing checkout. Set a branch, tag, or commit for reproducible builds.
UPSTREAM_REF=

# Normally written by the interactive menu.
DEVICE_PROFILE=

NIKKI_FEED_NAME=nikki
NIKKI_FEED_URL=https://github.com/nikkinikki-org/OpenWrt-nikki.git
NIKKI_FEED_BRANCH=main
NIKKI_MIHOMO_PROVIDER=mihomo-meta

# Empty means the scripts use nproc inside the container.
JOBS=
BUILD_VERBOSE=0
